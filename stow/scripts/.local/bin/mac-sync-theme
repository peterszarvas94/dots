#!/usr/bin/env bash
set -euo pipefail

THEME_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/omarchy/current/theme"
NVIM_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/nvim"
SERVER_REGISTRY="$NVIM_STATE_DIR/theme-sync-servers"
TMUX_REGISTRY="$NVIM_STATE_DIR/theme-sync-tmux"

mkdir -p "$THEME_DIR"

detect_mode() {
    if command -v dark-mode >/dev/null 2>&1; then
        if [[ "$(dark-mode status 2>/dev/null || true)" == "on" ]]; then
            echo "dark"
        else
            echo "light"
        fi
        return
    fi

    if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -q "Dark"; then
        echo "dark"
    else
        echo "light"
    fi
}

MODE="${1:-}"
if [[ "$MODE" != "dark" && "$MODE" != "light" ]]; then
    MODE="$(detect_mode)"
fi

if [[ "$MODE" == "dark" ]]; then
    GHOSTTY_THEME="Rose Pine"
else
    GHOSTTY_THEME="Rose Pine Dawn"
fi

TMP_NVIM="$THEME_DIR/neovim.lua.tmp"
TMP_GHOSTTY="$THEME_DIR/ghostty.conf.tmp"

cat > "$TMP_NVIM" <<EOF
return {
  background = '$MODE',
  colorscheme = 'rose-pine',
}
EOF

cat > "$TMP_GHOSTTY" <<EOF
theme = $GHOSTTY_THEME
EOF

mv "$TMP_NVIM" "$THEME_DIR/neovim.lua"
mv "$TMP_GHOSTTY" "$THEME_DIR/ghostty.conf"
printf '%s\n' "$MODE" > "$THEME_DIR/mode"

if [ -f "$SERVER_REGISTRY" ] && command -v nvim >/dev/null 2>&1; then
    LIVE_SERVERS=""

    while IFS= read -r SERVER || [ -n "$SERVER" ]; do
        [ -z "$SERVER" ] && continue

        if [ -S "$SERVER" ]; then
            nvim --server "$SERVER" --remote-send '<Cmd>silent! SyncTheme<CR>' >/dev/null 2>&1 || true
            LIVE_SERVERS="${LIVE_SERVERS}
${SERVER}"
        fi
    done < "$SERVER_REGISTRY"

    mkdir -p "$NVIM_STATE_DIR"
    printf '%s\n' "$LIVE_SERVERS" | awk 'NF && !seen[$0]++' > "$SERVER_REGISTRY"
fi

if command -v tmux >/dev/null 2>&1 && [ -f "$TMUX_REGISTRY" ]; then
    LIVE_PANES=""
    while IFS= read -r PANE || [ -n "$PANE" ]; do
        [ -z "$PANE" ] && continue
        tmux send-keys -t "$PANE" ':SyncTheme' C-m 2>/dev/null || true
        LIVE_PANES="${LIVE_PANES}
${PANE}"
    done < "$TMUX_REGISTRY"

    mkdir -p "$NVIM_STATE_DIR"
    printf '%s\n' "$LIVE_PANES" | awk 'NF && !seen[$0]++' > "$TMUX_REGISTRY"
fi
