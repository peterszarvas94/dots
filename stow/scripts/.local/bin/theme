#!/usr/bin/env bash
set -euo pipefail

CURRENT=$(gsettings get org.gnome.desktop.interface color-scheme)
CURRENT_THEME=$(omarchy-theme-current 2>/dev/null || true)

case "$CURRENT_THEME" in
  "Rose Pine Dark")
    TARGET_THEME="Rose Pine"
    ;;
  "Rose Pine")
    TARGET_THEME="Rose Pine Dark"
    ;;
  *)
    if [[ "$CURRENT" == *"prefer-dark"* ]]; then
      TARGET_THEME="Rose Pine"
    else
      TARGET_THEME="Rose Pine Dark"
    fi
    ;;
esac

omarchy-theme-set "$TARGET_THEME"

sleep 0.2

if command -v nvim >/dev/null 2>&1; then
  shopt -s nullglob
  sockets=("/run/user/$(id -u)/"nvim.* "/tmp/nvim.$USER/"*)
  for socket in "${sockets[@]}"; do
    if [[ -S "$socket" ]]; then
      nvim --server "$socket" --remote-send '<Cmd>SyncTheme!<CR>' >/dev/null 2>&1 || true
    fi
  done
  shopt -u nullglob
fi

echo "Set Omarchy theme to: $TARGET_THEME"
