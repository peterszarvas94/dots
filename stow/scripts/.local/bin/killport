#!/bin/bash

if [ "$#" -eq 0 ]; then
    echo "Usage: $0 <port> [port ...]"
    exit 1
fi

for port in "$@"; do
    pids=$(lsof -ti ":$port")

    if [ -z "$pids" ]; then
        echo "No processes found on port $port."
        continue
    fi

    for pid in $pids; do
        echo "Killing process $pid on port $port"
    done

    kill -9 $pids
done

echo "Done."
