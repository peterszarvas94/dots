#!/usr/bin/env bash

if [[ -n "$TMUX" ]]; then
    current_window="$(tmux display-message -p '#{session_name}:#{window_index}')"

    opencode_pane="$(tmux split-window -P -F '#{pane_id}' -h -t "$current_window" "opencode")"
    tmux rename-window -t "$current_window" "code"
    tmux set-window-option -t "$current_window" main-pane-width "67%"
    tmux select-layout -t "$current_window" main-vertical
    tmux select-pane -t "$opencode_pane"
fi

exec nvim .
