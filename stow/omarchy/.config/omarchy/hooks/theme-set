#!/usr/bin/env bash
set -euo pipefail

if ! command -v nvim >/dev/null 2>&1; then
  exit 0
fi

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
tmp_dir="/tmp/nvim.${USER}"

shopt -s nullglob
sockets=("${runtime_dir}"/nvim.* "${tmp_dir}"/*)
shopt -u nullglob

for socket in "${sockets[@]}"; do
  [[ -S "$socket" ]] || continue
  nvim --server "$socket" --remote-send '<Cmd>SyncTheme<CR>' >/dev/null 2>&1 || true
done
