{
	"title_bar": {
  "show_project_items": false,
  "show_onboarding_banner": false,
  "show_sign_in": false,
  "show_user_menu": false,
  "show_user_picture": false,
  "show_branch_name": false
 },
 "status_bar": {
  "active_language_button": false,
  "cursor_position_button": false
 },
 "debugger": {
  "button": false
 },
 "search": {
  "button": false
 },
 "global_lsp_settings": {
  "button": false
 },
 "edit_predictions": {
		"provider": "none",
	},
	"git_panel": {
		"button": false,
  "dock": "left",
	},
	"icon_theme": "Catppuccin Mocha",
	"vim_mode": true,
	"ui_font_size": 16,
	"buffer_font_size": 13,
	"theme": {
		"mode": "system",
		"light": "Catppuccin Latte",
		"dark": "Catppuccin Mocha",
	},
	"buffer_font_family": "JetBrainsMono Nerd Font",
	"buffer_line_height": {
		"custom": 1.8,
	},
	"terminal": {
		"button": false,
  "line_height": {
			"custom": 1.8,
		},
	},
	"relative_line_numbers": "enabled",
	"soft_wrap": "editor_width",
	"hard_tabs": true,
	"tab_size": 2,
	"toolbar": {
		"breadcrumbs": true,
		"quick_actions": false,
		"selections_menu": false,
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"collaboration_panel": {
		"dock": "left",
		"button": false,
	},
	"outline_panel": {
		"dock": "left",
		"button": false,
	},
	"indent_guides": {
		"enabled": true,
	},
	"git": {
		"inline_blame": {
			"enabled": false,
		},
	},
	"project_panel": {
		"button": false,
  "dock": "left",
		"indent_size": 10,
	},
	"tab_bar": {
		"show_tab_bar_buttons": false,
  "show_nav_history_buttons": false,
  "show": false,
	},
	"show_edit_predictions": false,
	"agent": {
		"dock": "right",
		"enabled": false,
		"button": false,
	},
	"scrollbar": {
		"diagnostics": "none",
		"git_diff": false,
		"search_results": false,
		"selected_symbol": false,
	},
	"diagnostics": {
		"button": false,
  "include_warnings": false,
	},
	"format_on_save": "on",
	"language_servers": ["typescript-language-server", "!eslint", "gopls", "..."],
	"languages": {
		"TypeScript": {
			"code_actions_on_format": {
				"source.organizeImports": true,
			},
			"formatter": "prettier",
		},
		"TSX": {
			"code_actions_on_format": {
				"source.organizeImports": true,
			},
			"formatter": "prettier",
		},
		"JavaScript": {
			"code_actions_on_format": {
				"source.organizeImports": true,
			},
			"formatter": "prettier",
		},
		"Go": {
			"code_actions_on_format": {
				"source.organizeImports": true,
			},
			"formatter": "language_server",
		},
		"JSON": {
			"formatter": "prettier",
		},
		"JSONC": {
			"formatter": "prettier",
		},
	},
}
